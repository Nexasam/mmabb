# Deny direct access to all files in the project root.
# Only the /public directory should be the web root on GoDaddy.
# If your host points to the project root instead of /public,
# use this to redirect everything to public/index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
